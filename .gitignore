# Build output — ignore everything in Debug by default...
/Debug/**

# ...but keep the generated makefiles so CI can build from a clean checkout
!/Debug/makefile
!/Debug/objects.list
!/Debug/objects.mk
!/Debug/sources.mk

# Keep the subfolder makefiles (CubeIDE puts sub-makefiles in Core/ and Drivers/)
!/Debug/Core/
!/Debug/Drivers/
!/Debug/Core/**/*.mk
!/Debug/Drivers/**/*.mk
!/Debug/Core/**/subdir.mk

# Python
/.venv/
__pycache__/
*.pyc
.pytest_cache/

# Build artifacts and test output (belt-and-suspenders)
*.o
*.d
*.elf
*.list
*.map
results.xml